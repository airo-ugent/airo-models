<robot name="schunk_egk40_magneto">
    <link name="base_link"/>
    <link name="adapter_plate">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0.005"/>
            <geometry>
                <box size="0.117 0.068 0.01"/>
            </geometry>
            <material name="">
                <color rgba="0.1 0.1 0.1 1"/>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0.005"/>
            <geometry>
                <box size="0.117 0.068 0.01"/>
            </geometry>
        </collision>
    </link>
    <link name="camera_mount_plate">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0.00175"/>
            <geometry>
                <box size="0.117 0.068 0.0035"/>
            </geometry>
            <material name="">
                <color rgba="1 1 0.1 1"/>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0.00175"/>
            <geometry>
                <box size="0.117 0.068 0.0035"/>
            </geometry>
        </collision>
    </link>
    <link name="pcb_mount_plate">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <box size="0.02 0.068 0.0835"/>
            </geometry>
            <material name="">
                <color rgba="1 1 0.1 1"/>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0.0"/>
            <geometry>
                <box size="0.02 0.068 0.0835"/>
            </geometry>
        </collision>
    </link>
    <link name="base_link_gripper">
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="1.02"/>
        </inertial>
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="../schunk_egk40/meshes/EGK40-MB-M-B.obj"/>
            </geometry>
            <material name="">
                <color rgba="0.1 0.1 0.1 1"/>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0.0418"/>
            <geometry>
                <box size="0.117 0.068 0.0835"/>
            </geometry>
        </collision>
        <collision>
            <origin rpy="0 0 0" xyz="0.06 0 0.03"/>
            <geometry>
                <box size="0.04 0.04 0.04"/>
            </geometry>
        </collision>
    </link>

    <link name="right_magneto_finger">
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.02"/>
        </inertial>
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="../fingertips/meshes/magneto_finger.obj"/>
            </geometry>
            <material name="">
                <color rgba="0.1 0.1 0.1 1"/>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0.04 -0.0155 0.0285"/>
            <geometry>
                <box size="0.025 0.025 0.057"/>
            </geometry>
        </collision>
    </link>

    <link name="left_magneto_finger">
        <inertial>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <mass value="0.02"/>
        </inertial>
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="../fingertips/meshes/magneto_finger.obj"/>
            </geometry>
            <material name="">
                <color rgba="0.1 0.1 0.1 1"/>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0.04 -0.0155 0.0285"/>
            <geometry>
                <box size="0.025 0.025 0.057"/>
            </geometry>
        </collision>
    </link>

    <joint name="base_link_to_adapter_plate" type="fixed">
        <parent link="base_link"/>
        <child link="adapter_plate"/>
    </joint>
    <joint name="adapter_plate_to_camera_mount_plate" type="fixed">
        <parent link="adapter_plate"/>
        <child link="camera_mount_plate"/>
        <origin xyz="0 0 0.01"/>
    </joint>
    <joint name="base_link_to_pcb_mount_plate" type="fixed">
        <parent link="base_link"/>
        <child link="pcb_mount_plate"/>
        <origin xyz="-0.0685 0 0.04175"/>
    </joint>

    <joint name="base_link_gripper_joint" type="fixed">
        <parent link="camera_mount_plate"/>
        <child link="base_link_gripper"/>
        <origin xyz="0 0 0.0035"/>
    </joint>

    <link name="right_finger_mount"/>
    <joint name="right_finger_mount_joint" type="prismatic">
        <parent link="base_link_gripper"/>
        <child link="right_finger_mount"/>
        <origin xyz="0.014 0.01711 0.0835" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <!--official stroke width 41.5mm-->
        <limit lower="-0.0415" upper="0" effort="10" velocity="0.1"/>
    </joint>

    <link name="left_finger_mount"/>
    <joint name="left_finger_mount_joint" type="prismatic">
        <parent link="base_link_gripper"/>
        <child link="left_finger_mount"/>
        <origin xyz="-0.014 -0.01711 0.0835" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="0" upper="0.0415" effort="10" velocity="0.1"/>
        <mimic joint="right_finger_mount_joint" multiplier="-1" offset="0"/>
    </joint>

    <joint name="right_finger_mount_to_tip" type="fixed">
        <parent link="right_finger_mount"/>
        <child link="right_magneto_finger"/>
        <origin xyz="0.0 0 0" rpy="0 0 0"/>
    </joint>

    <joint name="left_finger_mount_to_tip" type="fixed">
        <parent link="left_finger_mount"/>
        <child link="left_magneto_finger"/>
        <origin xyz="0 0 0" rpy="0 0 3.14"/>
    </joint>

    <!-- TCP at the fingertips' flat contact face (magneto_finger.obj's local z=0.057), at the
    fingers' zero-joint-value ("fully open") mount position. The mounts are point-symmetric
    (right: +0.0155,+0.01711; left: -0.0155,-0.01711) so each fingertip's local x/y offset
    cancels exactly in the average regardless of gripper opening, so only the z (reach) term
    survives: 0.0835 (finger mount height) plus 0.057 (fingertip local z-extent) = 0.1405. -->
    <link name="tcp"/>
    <joint name="base_link_gripper_to_tcp" type="fixed">
        <parent link="base_link_gripper"/>
        <child link="tcp"/>
        <origin xyz="0 0 0.1405" rpy="0 0 0"/>
    </joint>
</robot>